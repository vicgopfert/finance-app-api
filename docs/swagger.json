        "/api/users/me/balance": {
            "get": {
                "summary": "Get authenticated user balance",
                "description": "Endpoint to retrieve the authenticated user's balance information.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "from",
                        "in": "query",
                        "required": true,
                        "description": "Start date for filtering transactions (format: YYYY-MM-DD)",
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2025-01-01"
                        }
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "required": true,
                        "description": "End date for filtering transactions (format: YYYY-MM-DD)",
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2025-01-31"
                        }
                    }
                ],
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User balance information retrieved successfully",
                        "schema": {
                            "$ref": "#/definitions/UserBalance"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/auth/login": {
            "post": {
                "summary": "Login user and retrieve tokens",
                "description": "Endpoint to authenticate a user and retrieve access and refresh tokens.",
                "tags": ["Auth"],
                "security": [],
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/LoginUserParams"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "User authenticated successfully",
                        "schema": {
                            "$ref": "#/definitions/UserWithToken"
                        }
                    },
                    "401": {
                        "description": "Invalid credentials",
                        "schema": {
                            "$ref": "#/definitions/UnauthorizedErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/auth/refresh-token": {
            "post": {
                "summary": "Refresh user tokens",
                "description": "Endpoint to refresh the access and refresh tokens for an authenticated user.",
                "tags": ["Auth"],
                "security": [],
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/RefreshTokenParams"
                        }
                    }
                ],
                "responses": {
                    "201": {
                        "description": "Tokens generated successfully",
                        "schema": {
                            "$ref": "#/definitions/Tokens"
                        }
                    },
                    "401": {
                        "description": "Invalid token",
                        "schema": {
                            "$ref": "#/definitions/UnauthorizedErrorResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/transactions/me": {
            "get": {
                "summary": "Get authenticated user transactions",
                "description": "Endpoint to retrieve transactions for the authenticated user.",
                "tags": ["Transactions"],
                "parameters": [
                    {
                        "name": "from",
                        "in": "query",
                        "required": true,
                        "description": "Start date for filtering transactions (format: YYYY-MM-DD)",
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2025-01-01"
                        }
                    },
                    {
                        "name": "to",
                        "in": "query",
                        "required": true,
                        "description": "End date for filtering transactions (format: YYYY-MM-DD)",
                        "schema": {
                            "type": "string",
                            "format": "date",
                            "example": "2025-01-31"
                        }
                    }
                ],
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transactions retrieved successfully",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/Transaction"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "summary": "Create a new transaction for authenticated user",
                "description": "Endpoint to create a new transaction in the finance app.",
                "tags": ["Transactions"],
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/CreateTransactionParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction created successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction created successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/transactions/me/{id}": {
            "patch": {
                "summary": "Update transaction by ID of the authenticated user",
                "description": "Endpoint to update a transaction's information by its unique ID.",
                "tags": ["Transactions"],
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the transaction to update"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/UpdateTransactionParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction updated successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction updated successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "Transaction not found",
                        "schema": {
                            "$ref": "#/definitions/TransactionNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete transaction by ID of the authenticated user",
                "description": "Endpoint to delete a transaction by its unique ID.",
                "tags": ["Transactions"],
                "security": [
                    {
                        "BearerAuth": []
                    }
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the transaction to delete"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction deleted successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction deleted successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Transaction not found",
                        "schema": {
                            "$ref": "#/definitions/TransactionNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "User": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "Unique identifier for the user"
                },
                "first_name": {
                    "type": "string",
                    "example": "John",
                    "description": "First name of the user"
                },
                "last_name": {
                    "type": "string",
                    "example": "Doe",
                    "description": "Last name of the user"
                },
                "email": {
                    "type": "string",
                    "example": "user@example.com",
                    "description": "Email address of the user"
                },
                "password": {
                    "type": "string",
                    "example": "password123",
                    "description": "Password of the user"
                }
            }
        },
        "UserWithToken": {
            "allOf": [
                {
                    "$ref": "#/definitions/User"
                },
                {
                    "type": "object",
                    "properties": {
                        "accessToken": {
                            "type": "string",
                            "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
                        },
                        "refreshToken": {
                            "type": "string",
                            "example": "dGhpc2lzYXJlZnJlc2hhY2tlci..."
                        }
                    }
                }
            ]
        },
        "Tokens": {
            "type": "object",
            "properties": {
                "accessToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI1M2U0ODRjNS02MjVmLTRmZGItODBhNC1kNjkwMjBmMWRhZjYiLCJpYXQiOjE3ODIxMzc0MTIsImV4cCI6MTc4MjEzODMxMn0.wGGCkOH8TfdcjsP76Yme9bXYGPBbBkH6LXNQDmFoRgA"
                },
                "refreshToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI1M2U0ODRjNS02MjVmLTRmZGItODBhNC1kNjkwMjBmMWRhZjYiLCJpYXQiOjE3ODIxMzc0MTIsImV4cCI6MTc4NDcyOTQxMn0.xlGMyggGHyTiamwziT15uJs-sI6hAQWUknf0x1D8Fdc"
                }
            }
        },
        "UserBalance": {
            "type": "object",
            "properties": {
                "earnings": {
                    "type": "string",
                    "example": "5000.0",
                    "description": "Total earnings of the user"
                },
                "expenses": {
                    "type": "string",
                    "example": "2000.0",
                    "description": "Total expenses of the user"
                },
                "investments": {
                    "type": "string",
                    "example": "1000.0",
                    "description": "Total investments of the user"
                },
                "earningsPercentage": {
                    "type": "string",
                    "example": "63.0",
                    "description": "Percentage of earnings relative to total transactions"
                },
                "expensesPercentage": {
                    "type": "string",
                    "example": "25.0",
                    "description": "Percentage of expenses relative to total transactions"
                },
                "investmentsPercentage": {
                    "type": "string",
                    "example": "12.0",
                    "description": "Percentage of investments relative to total transactions"
                },
                "balance": {
                    "type": "string",
                    "example": "2000.0",
                    "description": "Current balance of the user (earnings - expenses + investments)"
                }
            }
        },
        "CreateUserParams": {
            "type": "object",
            "properties": {
                "first_name": {
                    "type": "string",
                    "example": "John",
                    "description": "First name of the user"
                },
                "last_name": {
                    "type": "string",
                    "example": "Doe",
                    "description": "Last name of the user"
                },
                "email": {
                    "type": "string",
                    "example": "user@example.com",
                    "description": "Email address of the user"
                },
                "password": {
                    "type": "string",
                    "example": "password123",
                    "description": "Password of the user"
                }
            },
            "required": ["first_name", "last_name", "email", "password"]
        },
        "LoginUserParams": {
            "type": "object",
            "properties": {
                "email": {
                    "type": "string",
                    "example": "user@example.com",
                    "description": "Email address of the user"
                },
                "password": {
                    "type": "string",
                    "example": "password123",
                    "description": "Password of the user"
                }
            },
            "required": ["email", "password"]
        },
        "RefreshTokenParams": {
            "type": "object",
            "properties": {
                "refreshToken": {
                    "type": "string",
                    "example": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJ1c2VySWQiOiI1M2U0ODRjNS02MjVmLTRmZGItODBhNC1kNjkwMjBmMWRhZjYiLCJpYXQiOjE3ODIxMzc0MTIsImV4cCI6MTc4NDcyOTQxMn0.xlGMyggGHyTiamwziT15uJs-sI6hAQWUknf0x1D8Fdc",
                    "description": "Refresh token of the user"
                }
            },
            "required": ["refreshToken"]
        },
        "UserNotFoundResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "User not found."
                }
            }
        },
        "InvalidParamsResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Invalid param (this depends on the param that is invalid)"
                }
            }
        },
        "InternalServerErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Internal server error"
                }
            }
        },
        "UnauthorizedErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Unauthorized"
                }
            }
        },
        "Transaction": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "Unique identifier for the transaction"
                },
                "user_id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "ID of the user owner of the transaction"
                },
                "name": {
                    "type": "string",
                    "example": "Salary",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-01T12:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "string",
                    "example": "10000.0",
                    "description": "Transaction amount"
                }
            }
        },
        "CreateTransactionParams": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Salary",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-01T12:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "string",
                    "example": "10000.0",
                    "description": "Transaction amount"
                }
            },
            "required": ["name", "date", "type", "amount"]
        },
        "UpdateTransactionParams": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Updated name",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-02T08:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "string",
                    "example": "150.0",
                    "description": "Transaction amount"
                }
            }
        },
        "TransactionNotFoundResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Transaction with id 123e4567-e89b-12d3-a456-426614174000 not found."
                }
            }
        }
    }
}
