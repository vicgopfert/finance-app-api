{
    "swagger": "2.0",
    "info": {
        "version": "1.0.0",
        "title": "Finance App API",
        "description": "API Finance App that allows users to manage their finances."
    },
    "paths": {
        "/api/users": {
            "post": {
                "summary": "Create a new user",
                "description": "Endpoint to create a new user in the finance app.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/CreateUserParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User created successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "User created successfully"
                                },
                                "user": {
                                    "$ref": "#/definitions/User"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/users/{id}/balance": {
            "get": {
                "summary": "Get user balance by ID",
                "description": "Endpoint to retrieve a user's balance information by their unique ID.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the user to get balance information for"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User balance information retrieved successfully",
                        "schema": {
                            "$ref": "#/definitions/UserBalance"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/users/{id}": {
            "get": {
                "summary": "Get user by ID",
                "description": "Endpoint to retrieve a user by their unique ID.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the user to get"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User found successfully",
                        "schema": {
                            "$ref": "#/definitions/User"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "patch": {
                "summary": "Update user by ID",
                "description": "Endpoint to update a user's information by their unique ID.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the user to update"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/CreateUserParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User updated successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "User updated successfully"
                                },
                                "user": {
                                    "$ref": "#/definitions/User"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete user by ID",
                "description": "Endpoint to delete a user by their unique ID.",
                "tags": ["Users"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the user to delete"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "User deleted successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "User deleted successfully"
                                },
                                "user": {
                                    "$ref": "#/definitions/User"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/transactions": {
            "get": {
                "summary": "Get transactions by user ID",
                "description": "Endpoint to retrieve transactions for a given user by their unique ID (query param `userId`).",
                "tags": ["Transactions"],
                "parameters": [
                    {
                        "name": "userId",
                        "in": "query",
                        "required": true,
                        "type": "string",
                        "description": "ID of the user to get transactions for"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transactions retrieved successfully",
                        "schema": {
                            "type": "array",
                            "items": {
                                "$ref": "#/definitions/Transaction"
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "post": {
                "summary": "Create a new transaction",
                "description": "Endpoint to create a new transaction in the finance app.",
                "tags": ["Transactions"],
                "parameters": [
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/CreateTransactionParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction created successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction created successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "User not found",
                        "schema": {
                            "$ref": "#/definitions/UserNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        },
        "/api/transactions/{id}": {
            "patch": {
                "summary": "Update transaction by ID",
                "description": "Endpoint to update a transaction's information by its unique ID.",
                "tags": ["Transactions"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the transaction to update"
                    },
                    {
                        "name": "body",
                        "in": "body",
                        "required": true,
                        "schema": {
                            "$ref": "#/definitions/UpdateTransactionParams"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction updated successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction updated successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "400": {
                        "description": "Invalid params",
                        "schema": {
                            "$ref": "#/definitions/InvalidParamsResponse"
                        }
                    },
                    "404": {
                        "description": "Transaction not found",
                        "schema": {
                            "$ref": "#/definitions/TransactionNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            },
            "delete": {
                "summary": "Delete transaction by ID",
                "description": "Endpoint to delete a transaction by its unique ID.",
                "tags": ["Transactions"],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "type": "string",
                        "description": "ID of the transaction to delete"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "Transaction deleted successfully",
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "example": "Transaction deleted successfully"
                                },
                                "transaction": {
                                    "$ref": "#/definitions/Transaction"
                                }
                            }
                        }
                    },
                    "404": {
                        "description": "Transaction not found",
                        "schema": {
                            "$ref": "#/definitions/TransactionNotFoundResponse"
                        }
                    },
                    "500": {
                        "description": "Internal server error",
                        "schema": {
                            "$ref": "#/definitions/InternalServerErrorResponse"
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "User": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "Unique identifier for the user"
                },
                "first_name": {
                    "type": "string",
                    "example": "John",
                    "description": "First name of the user"
                },
                "last_name": {
                    "type": "string",
                    "example": "Doe",
                    "description": "Last name of the user"
                },
                "email": {
                    "type": "string",
                    "example": "user@example.com",
                    "description": "Email address of the user"
                },
                "password": {
                    "type": "string",
                    "example": "password123",
                    "description": "Password of the user"
                }
            }
        },
        "UserBalance": {
            "type": "object",
            "properties": {
                "earnings": {
                    "type": "string",
                    "example": "5000.0",
                    "description": "Total earnings of the user"
                },
                "expenses": {
                    "type": "string",
                    "example": "2000.0",
                    "description": "Total expenses of the user"
                },
                "investments": {
                    "type": "string",
                    "example": "1000.0",
                    "description": "Total investments of the user"
                },
                "balance": {
                    "type": "string",
                    "example": "2000.0",
                    "description": "Current balance of the user (earnings - expenses + investments)"
                }
            }
        },
        "CreateUserParams": {
            "type": "object",
            "properties": {
                "first_name": {
                    "type": "string",
                    "example": "John",
                    "description": "First name of the user"
                },
                "last_name": {
                    "type": "string",
                    "example": "Doe",
                    "description": "Last name of the user"
                },
                "email": {
                    "type": "string",
                    "example": "user@example.com",
                    "description": "Email address of the user"
                },
                "password": {
                    "type": "string",
                    "example": "password123",
                    "description": "Password of the user"
                }
            }
        },
        "UserNotFoundResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "User with id 123e4567-e89b-12d3-a456-426614174000 not found."
                }
            }
        },
        "InvalidParamsResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Invalid param (this depends on the param that is invalid)"
                }
            }
        },
        "InternalServerErrorResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Internal server error"
                }
            }
        },
        "Transaction": {
            "type": "object",
            "properties": {
                "id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "Unique identifier for the transaction"
                },
                "user_id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "ID of the user owner of the transaction"
                },
                "name": {
                    "type": "string",
                    "example": "Salary",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-01T12:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "string",
                    "example": "10000.0",
                    "description": "Transaction amount"
                }
            }
        },
        "CreateTransactionParams": {
            "type": "object",
            "properties": {
                "user_id": {
                    "type": "string",
                    "example": "123e4567-e89b-12d3-a456-426614174000",
                    "description": "ID of the user who owns the transaction"
                },
                "name": {
                    "type": "string",
                    "example": "Salary",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-01T12:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "number",
                    "example": 10000.0,
                    "description": "Transaction amount"
                }
            }
        },
        "UpdateTransactionParams": {
            "type": "object",
            "properties": {
                "name": {
                    "type": "string",
                    "example": "Updated name",
                    "description": "Transaction name or description"
                },
                "date": {
                    "type": "string",
                    "example": "2026-06-02T08:00:00Z",
                    "description": "ISO 8601 datetime of the transaction"
                },
                "type": {
                    "type": "string",
                    "example": "EARNING",
                    "description": "Transaction type: EXPENSE, EARNING or INVESTMENT"
                },
                "amount": {
                    "type": "number",
                    "example": 150.0,
                    "description": "Transaction amount"
                }
            }
        },
        "TransactionNotFoundResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "type": "string",
                    "example": "Transaction with id 123e4567-e89b-12d3-a456-426614174000 not found."
                }
            }
        }
    }
}
